import matplotlib.pyplot as plt
import numpy as np

def analyze_input(user_input):
    
    # Predict probability
    if "http" in user_input:
        feat = np.array(extract_url_features(user_input)).reshape(1,-1)
        prob = model_url.predict_proba(feat)[0][1]
    else:
        vec = vectorizer.transform([user_input])
        prob = model_text.predict_proba(vec)[0][1]
    
    fraud_percent = prob * 100
    safe_percent = 100 - fraud_percent

    # Risk Level
    if fraud_percent > 75:
        risk = "HIGH RISK ð´"
    elif fraud_percent > 40:
        risk = "MEDIUM RISK ð "
    else:
        risk = "LOW RISK ð¢"

    print(f"Fraud Probability: {fraud_percent:.2f}%")
    print(f"Safe Probability: {safe_percent:.2f}%")
    print(f"Risk Level: {risk}")

    # ð PIE CHART
    plt.figure(figsize=(10,4))

    plt.subplot(1,2,1)
    plt.pie(
        [fraud_percent, safe_percent],
        labels=['Fraud','Safe'],
        autopct='%1.1f%%',
        colors=['red','green']
    )
    plt.title("Fraud vs Safe")

    # ð BAR GRAPH
    plt.subplot(1,2,2)
    plt.bar(['Fraud','Safe'], [fraud_percent, safe_percent], color=['red','green'])
    plt.title("Risk Analysis")
    plt.ylabel("Percentage")

    plt.tight_layout()
    plt.show()

    return fraud_percent, safe_percent, risk


