def predict_input(input_text):
    
    if "http" in input_text:
        feat = np.array(extract_url_features(input_text)).reshape(1,-1)
        prob = model_url.predict_proba(feat)[0][1]
    else:
        vec = vectorizer.transform([input_text])
        prob = model_text.predict_proba(vec)[0][1]
    
    return prob * 100


