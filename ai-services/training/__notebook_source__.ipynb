import pandas as pd
import numpy as np

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import classification_report

from sklearn.ensemble import RandomForestClassifier
from sklearn.linear_model import LogisticRegression
from xgboost import XGBClassifier

from sklearn.feature_extraction.text import TfidfVectorizer
from imblearn.over_sampling import SMOTE

import joblib


df = pd.read_csv('/kaggle/input/datasets/organizations/mlg-ulb/creditcardfraud/creditcard.csv')

X = df.drop('Class', axis=1)
y = df['Class']

scaler = StandardScaler()
X['Amount'] = scaler.fit_transform(X[['Amount']])

X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)

sm = SMOTE()
X_res, y_res = sm.fit_resample(X_train, y_train)

model_txn = XGBClassifier(n_estimators=50)
model_txn.fit(X_res, y_res)

print("✅ Transaction Model Ready")


msg_df = pd.read_csv('/kaggle/input/datasets/organizations/uciml/sms-spam-collection-dataset/spam.csv', encoding='latin-1')

msg_df = msg_df[['v1', 'v2']]
msg_df.columns = ['label', 'text']

msg_df['label'] = msg_df['label'].map({'ham':0, 'spam':1})

vectorizer = TfidfVectorizer()
X_text = vectorizer.fit_transform(msg_df['text'])
y_text = msg_df['label']

X_train_t, X_test_t, y_train_t, y_test_t = train_test_split(X_text, y_text, test_size=0.2)

model_msg = LogisticRegression()
model_msg.fit(X_train_t, y_train_t)

print("✅ Message Model Ready")


print(web_df.columns)


X_web = web_df.drop('result', axis=1)
y_web = web_df['result']


web_df = pd.read_csv('/kaggle/input/datasets/sandunabeysooriya/phishing-detection-dataset/fixed_values_ds.csv')

X_web = web_df.drop('result', axis=1)
y_web = web_df['result']

from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier

X_train_w, X_test_w, y_train_w, y_test_w = train_test_split(X_web, y_web, test_size=0.2)

model_web = RandomForestClassifier()
model_web.fit(X_train_w, y_train_w)

print("✅ Website Model Ready")


joblib.dump(model_txn, "/kaggle/working/txn_model.pkl")
joblib.dump(model_msg, "/kaggle/working/msg_model.pkl")
joblib.dump(model_web, "/kaggle/working/web_model.pkl")
joblib.dump(vectorizer, "/kaggle/working/vectorizer.pkl")

print("✅ All models saved")


def fraud_fusion(txn_input, msg_input, web_input):
    
    txn_score = model_txn.predict_proba(txn_input)[0][1]
    
    msg_vec = vectorizer.transform([msg_input])
    msg_score = model_msg.predict_proba(msg_vec)[0][1]
    
    web_score = model_web.predict_proba(web_input)[0][1]
    
    final_score = (txn_score * 0.5 + msg_score * 0.3 + web_score * 0.2)
    
    if final_score > 0.7:
        return "🚨 FRAUD", final_score
    elif final_score > 0.4:
        return "⚠️ SUSPICIOUS", final_score
    else:
        return "✅ SAFE", final_score


txn_sample = X_test.iloc[[0]]
msg_sample = "URGENT! Click now to claim prize money!"
web_sample = X_test_w.iloc[[0]]

result, score = fraud_fusion(txn_sample, msg_sample, web_sample)

print("Result:", result)
print("Risk Score:", score)


result, score = fraud_fusion(txn_sample, msg_sample, web_sample)

print("🔍 Result:", result)
print("📊 Risk Score:", round(score*100, 2), "%")


def explain(txn_score, msg_score, web_score):
    reasons = []
    
    if txn_score > 0.5:
        reasons.append("Unusual transaction pattern")
    if msg_score > 0.5:
        reasons.append("Suspicious message content")
    if web_score > 0.5:
        reasons.append("Phishing website detected")
        
    return reasons


